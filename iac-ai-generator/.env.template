# Terraform AI Agent - Configuration Template
# Copy this to .env or set as environment variables

# ========================================
# LLM API Configuration
# ========================================

# Get your free API key from: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Alternative API key (if not using OpenRouter)
# LLM_API_KEY=your-api-key-here

# LLM Model Selection
# Options: mistralai/mistral-7b-instruct (default), openai/gpt-4, openai/gpt-3.5-turbo, etc.
LLM_MODEL=mistralai/mistral-7b-instruct

# ========================================
# FastAPI Server Configuration (optional)
# ========================================

# Server host
HOST=0.0.0.0

# Server port
PORT=8000

# ========================================
# Logging Configuration (optional)
# ========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========================================
# Optional: Cloud-Specific Settings
# ========================================

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=

# AWS
AWS_REGION=us-east-1

# GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ========================================
# Development Settings (optional)
# ========================================

# Set to True for development
DEBUG=False

# Enable CORS for API
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========================================
# Usage Instructions
# ========================================

# Option 1: Set environment variables directly
# export OPENROUTER_API_KEY="sk-or-..."

# Option 2: Create .env file and load it
# cp .env.template .env
# source .env

# Option 3: Use in Python
# import os
# os.environ['OPENROUTER_API_KEY'] = 'sk-or-...'

# ========================================
# Get Your Free API Key
# ========================================

# 1. Visit: https://openrouter.ai
# 2. Sign up (free)
# 3. Copy your API key
# 4. Set OPENROUTER_API_KEY environment variable
# 5. Run: python agent.py "your prompt" --cloud azure

# ========================================
# Getting Started
# ========================================

# 1. Fill in your OPENROUTER_API_KEY above
# 2. Save this file as .env
# 3. Load environment: source .env
# 4. Run: python test_agent.py
# 5. Generate code: python agent.py "requirement" --cloud azure
